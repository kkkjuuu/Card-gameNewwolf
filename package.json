{
  "name": "werewolf-game",
  "version": "1.0.0",
  "description": "🐺 Werewolf / Mafia multiplayer game — Thai language, dark gothic aesthetic",
  "main": "server.js",
  "scripts": {
    "start": "node -e \"const fs=require('fs');let s=fs.readFileSync('server.js','utf8');s=s.replace(/^\\uFEFF/,'').replace(/\\u2013/g,'--');fs.writeFileSync('server.js',s,'utf8');\" && node server.js"
    "dev": "nodemon server.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "license": "MIT"
}
